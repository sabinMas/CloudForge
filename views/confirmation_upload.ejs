<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/styles/styles.css">
    <link rel="stylesheet" href="/styles/confirmation.css">
    <title>Upload Confirmation</title>
</head>

<body>

<%- include('partials/navbar',{user: user}) %>

<div class="confirmation-container">

<h2>Upload Successful!</h2>

<p>Your card has been uploaded successfully.</p>

<div class="confirmation-details">

<table>

<% if (image) { %>
<tr>
  <td>Image:</td>
  <td><img src="/uploads/<%= image %>" alt="<%= formData.name %>" style="max-width:200px; border-radius:8px;"></td>
</tr>
<% } %>

<tr>
<td>Title:</td>
<td><%= formData.name %></td>
</tr>

<tr>
<td>Category:</td>
<td><%= formData.category %></td>
</tr>

<tr>
<td>Rating:</td>
<td><%= formData.rate %></td>
</tr>

<tr>
<td>Stats:</td>
<td><%= formData.stat %></td>
</tr>

<tr>
<td>Price:</td>
<td><%= formData.price %></td>
</tr>

<tr>
<td>History:</td>
<td><%= formData.history %></td>
</tr>

</table>

</div>

<a href="/upload">Upload Another Card</a>

</div>
<%- include('partials/footer') %>
</body>
</html>
