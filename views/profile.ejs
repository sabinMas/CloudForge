<!--
    Author: Mason
    Description: User dashboard page — shows profile hero bar and uploaded cards grid.
    This should now be at the point where there is no hardcoded placeholder cards,
    they should be queried directly from the database.
-->

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/styles/styles.css">
  <link rel="stylesheet" href="/styles/profile.css">
  <title>Dashboard</title>
</head>

<body>
  <%- include('partials/navbar', {user: user}) %>

  <!-- Hero / Profile Bar -->
  <section id="profile-hero">
    <div id="profile-hero-inner">
      <div id="profile-avatar">
        <span id="avatar-icon">👤</span>
      </div>
      <div id="profile-info">
        <h2 id="profile-name">
          <% if (user) { %>
            <%= user.fname %> <%= user.lname %>
          <% } else { %>
            Guest User
          <% } %>
        </h2>
      </div>
      <div id="profile-actions">
        <a href="/upload" class="profile-btn">+ Upload Card</a>
        <a href="/signout" class="profile-btn profile-btn-secondary">Sign Out</a>
      </div>
    </div>
  </section>

  <!-- My Cards Section -->
  <section id="my-cards-section">
    <h3 id="my-cards-title">
      My Cards (<%= userCards.length %>)
    </h3>

    <% if (userCards.length === 0) { %>
      <p style="color: var(--text-muted); text-align: center; padding: 40px 0;">
        You haven't uploaded any cards yet.
        <a href="/upload">Upload your first card!</a>
      </p>
    <% } else { %>
      <div id="profile-card-grid">
        <% for (let card of userCards) { %>
          <div class="profile-card">
            <div class="profile-card-img-wrapper">
              <% if (card.image) { %>
                <img src="/uploads/<%= card.image %>" alt="<%= card.name %>">
              <% } else { %>
                <img src="/graphics/460x640.svg" alt="Card placeholder">
              <% } %>
            </div>
            <div class="profile-card-info">
              <span class="profile-card-title"><%= card.name %></span>
              <span class="profile-card-rating">Rating: <%= card.rate %> · $<%= Number(card.price).toLocaleString() %></span>
              <span style="font-size:0.78rem; color: var(--text-muted); text-transform: capitalize;"><%= card.category %></span>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </section>

  <%- include('partials/footer') %>
</body>

</html>
